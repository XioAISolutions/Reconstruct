{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XioAISolutions/Reconstruct/blob/main/packages/appspec/schema/appspec.schema.json",
  "title": "Reconstruct AppSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["version","generatedAt","app","screens","components","flows","designSystem","assumptions","unknowns","acceptanceTests","capture","integrity"],
  "properties": {
    "version": {"const":"0.2.0"},
    "generatedAt": {"type":"string","format":"date-time"},
    "app": {
      "type":"object","additionalProperties":false,"required":["name","sourceUrl"],
      "properties": {
        "name":{"type":"string","minLength":1,"maxLength":300},
        "sourceUrl":{"type":"string","format":"uri","pattern":"^https?://"},
        "description":{"type":"string","maxLength":2000}
      }
    },
    "screens":{"type":"array","maxItems":5000,"items":{"$ref":"#/$defs/screen"}},
    "components":{"type":"array","maxItems":5000,"items":{"$ref":"#/$defs/component"}},
    "flows":{"type":"array","maxItems":5000,"items":{"$ref":"#/$defs/flow"}},
    "designSystem": {
      "type":"object","additionalProperties":false,"required":["colors","typography","spacing","radii"],
      "properties": {
        "colors":{"type":"object","additionalProperties":{"type":"string"}},
        "typography":{"type":"object","additionalProperties":{"type":"string"}},
        "spacing":{"type":"object","additionalProperties":{"type":"string"}},
        "radii":{"type":"object","additionalProperties":{"type":"string"}}
      }
    },
    "assumptions":{"type":"array","maxItems":5000,"items":{"type":"string","maxLength":2000}},
    "unknowns":{"type":"array","maxItems":5000,"items":{"type":"string","maxLength":2000}},
    "acceptanceTests":{"type":"array","maxItems":5000,"items":{"$ref":"#/$defs/acceptanceTest"}},
    "capture": {
      "type":"object","additionalProperties":true,
      "required":["mode","startedAt","completedAt","toolVersion","viewport","limits","requestCount","truncated"],
      "properties": {
        "mode":{"const":"public"},
        "startedAt":{"type":"string","format":"date-time"},
        "completedAt":{"type":"string","format":"date-time"},
        "toolVersion":{"type":"string","maxLength":50},
        "viewport": {
          "type":"object","required":["width","height"],
          "properties": {
            "width":{"type":"integer","minimum":320,"maximum":3840},
            "height":{"type":"integer","minimum":320,"maximum":2160}
          }
        },
        "limits":{"type":"object"},
        "requestCount":{"type":"integer","minimum":0},
        "blockedRequestCount":{"type":"integer","minimum":0},
        "observedHosts":{"type":"array","items":{"type":"string"}},
        "truncated":{"type":"boolean"},
        "webSocketsBlocked":{"type":"boolean"},
        "screenshotMethod":{"enum":["playwright-clip","playwright-viewport","cdp"]}
      }
    },
    "integrity": {
      "type":"object","additionalProperties":false,"required":["algorithm","manifest"],
      "properties": {
        "algorithm":{"const":"sha256"},
        "manifest":{"$ref":"#/$defs/relativePath"}
      }
    }
  },
  "$defs": {
    "id":{"type":"string","pattern":"^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "relativePath": {
      "type":"string","minLength":1,"maxLength":1024,
      "not":{"pattern":"(^/|\\\\|(^|/)\\.\\.?(/|$)|^[A-Za-z]:)"}
    },
    "assessment": {
      "type":"object","additionalProperties":false,"required":["status","confidence"],
      "properties": {
        "status":{"enum":["observed","inferred","unknown"]},
        "confidence":{"type":"number","minimum":0,"maximum":1},
        "reason":{"type":"string","maxLength":2000}
      }
    },
    "evidence": {
      "type":"object","additionalProperties":false,"required":["type","path","sha256","bytes"],
      "properties": {
        "type":{"enum":["screenshot","html","dom","interaction","manual","manifest"]},
        "path":{"$ref":"#/$defs/relativePath"},
        "sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},
        "bytes":{"type":"integer","minimum":0},
        "mediaType":{"type":"string","maxLength":200}
      }
    },
    "screen": {
      "type":"object","additionalProperties":false,
      "required":["id","route","title","assessment","components","evidence"],
      "properties": {
        "id":{"$ref":"#/$defs/id"},
        "route":{"type":"string","pattern":"^/","maxLength":2048},
        "title":{"type":"string","maxLength":300},
        "assessment":{"$ref":"#/$defs/assessment"},
        "components":{"type":"array","items":{"$ref":"#/$defs/id"}},
        "evidence":{"type":"array","maxItems":2000,"items":{"$ref":"#/$defs/evidence"}}
      }
    },
    "component": {
      "type":"object","additionalProperties":false,
      "required":["id","name","type","states","assessment","evidence"],
      "properties": {
        "id":{"$ref":"#/$defs/id"},
        "name":{"type":"string","minLength":1,"maxLength":300},
        "type":{"type":"string","minLength":1,"maxLength":100},
        "states":{"type":"array","items":{"type":"string","maxLength":100}},
        "assessment":{"$ref":"#/$defs/assessment"},
        "evidence":{"type":"array","maxItems":2000,"items":{"$ref":"#/$defs/evidence"}}
      }
    },
    "flow": {
      "type":"object","additionalProperties":false,
      "required":["id","name","steps","assessment","evidence"],
      "properties": {
        "id":{"$ref":"#/$defs/id"},
        "name":{"type":"string","minLength":1,"maxLength":300},
        "steps":{"type":"array","minItems":1,"items":{"type":"string","maxLength":1000}},
        "assessment":{"$ref":"#/$defs/assessment"},
        "evidence":{"type":"array","maxItems":2000,"items":{"$ref":"#/$defs/evidence"}}
      }
    },
    "acceptanceTest": {
      "type":"object","additionalProperties":false,"required":["id","given","when","then"],
      "properties": {
        "id":{"$ref":"#/$defs/id"},
        "given":{"type":"string","minLength":1,"maxLength":2000},
        "when":{"type":"string","minLength":1,"maxLength":2000},
        "then":{"type":"string","minLength":1,"maxLength":2000}
      }
    }
  }
}
