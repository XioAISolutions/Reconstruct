{
  "name": "reconstruct",
  "version": "0.3.0",
  "private": true,
  "description": "Open-source application reconstruction engine for AI coding agents",
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.2",
  "engines": {"node": ">=20.19.0 <25", "npm": ">=10"},
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node --test packages/cli/integration/*.test.js",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "node scripts/repo-check.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build",
    "reconstruct": "node run.js"
  },
  "workspaces": ["packages/*"],
  "type": "module"
}
